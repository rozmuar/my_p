# Database Configuration
DB_NAME=postapi
DB_USERNAME=postgres
DB_PASSWORD=postgres123
DB_PORT=5432

# Redis Configuration
REDIS_PORT=6379

# Backend Configuration
BACKEND_PORT=3001
JWT_SECRET=your-production-jwt-secret-please-change-this-in-production
SESSION_SECRET=your-session-secret-please-change-this-in-production
BCRYPT_ROUNDS=12
MAX_FILE_SIZE=10485760
CORS_ORIGIN=http://localhost:3000

# Frontend Configuration
FRONTEND_PORT=3000
VITE_API_URL=http://localhost:3001
VITE_APP_NAME=PostAPI
VITE_APP_VERSION=2.0.0

# Development Tools (for docker-compose.dev.yml)
PGADMIN_EMAIL=admin@postapi.local
PGADMIN_PASSWORD=admin123
PGADMIN_PORT=8080

# Production specific (optional)
NODE_ENV=production